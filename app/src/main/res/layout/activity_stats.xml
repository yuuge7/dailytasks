<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="?android:attr/windowBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Statistici și Progres"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="32dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Imagine de Ansamblu"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#3F51B5"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:id="@+id/txtTotalCompletions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Total finalizate: 0"
            android:textSize="16sp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/txtActiveTasks"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Task-uri urmărite: 0"
            android:textSize="16sp"
            android:layout_marginBottom="16dp"/>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Top Serii de Foc 🔥"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FF9800"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:id="@+id/layoutStreaks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp"/>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Activitate Recentă"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#4CAF50"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:id="@+id/txtToday"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Astăzi: 0"
            android:textSize="16sp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/txtYesterday"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ieri: 0"
            android:textSize="16sp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/txtThisMonth"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Luna aceasta: 0"
            android:textSize="16sp"/>

    </LinearLayout>
</ScrollView>